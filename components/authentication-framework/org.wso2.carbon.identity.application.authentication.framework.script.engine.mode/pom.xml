<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <parent>
        <groupId>org.wso2.carbon.identity.framework</groupId>
        <artifactId>authentication-framework</artifactId>
        <version>7.10.150-SNAPSHOT</version>
        <relativePath>../pom.xml</relativePath>
    </parent>
    <modelVersion>4.0.0</modelVersion>
    <groupId>org.wso2.carbon.identity.framework</groupId>
    <packaging>bundle</packaging>
    <artifactId>org.wso2.carbon.identity.application.authentication.framework.script.engine.mode</artifactId>
    <version>1.0.0-SNAPSHOT</version>
    <name>WSO2 Carbon - Script Engine Mode Resolver for Authentication Framework</name>

    <dependencies>
        <!--Commons Logging-->
        <dependency>
            <groupId>commons-logging</groupId>
            <artifactId>commons-logging</artifactId>
            <version>1.2</version>
            <scope>provided</scope>
        </dependency>
        <!--OSGi service component annotations-->
        <dependency>
            <groupId>org.osgi</groupId>
            <artifactId>org.osgi.service.component</artifactId>
            <version>1.3.0</version>
            <scope>provided</scope>
        </dependency>
        <dependency>
            <groupId>org.osgi</groupId>
            <artifactId>org.osgi.service.component.annotations</artifactId>
            <version>1.3.0</version>
            <scope>provided</scope>
        </dependency>
        <!--OSGi core framework (for BundleContext used by ComponentContext)-->
        <dependency>
            <groupId>org.eclipse.osgi</groupId>
            <artifactId>org.eclipse.osgi</artifactId>
            <version>3.9.1.v20130814-1242</version>
            <scope>provided</scope>
        </dependency>
        <!--Identity core (for MessageContext, extended by AuthenticationContext)-->
        <dependency>
            <groupId>org.wso2.carbon.identity.framework</groupId>
            <artifactId>org.wso2.carbon.identity.core</artifactId>
            <version>${project.parent.version}</version>
            <scope>provided</scope>
            <optional>true</optional>
            <exclusions>
                <exclusion>
                    <groupId>*</groupId>
                    <artifactId>*</artifactId>
                </exclusion>
            </exclusions>
        </dependency>
        <!--
        Framework dependency for compile-time interfaces only.
        Marked as provided + optional to avoid transitive dependency resolution.
        All transitive dependencies excluded - we only need the interfaces for compilation.
        OSGi container will provide these classes at runtime.
        -->
        <dependency>
            <groupId>org.wso2.carbon.identity.framework</groupId>
            <artifactId>org.wso2.carbon.identity.application.authentication.framework</artifactId>
            <version>${project.parent.version}</version>
            <scope>provided</scope>
            <optional>true</optional>
            <exclusions>
                <exclusion>
                    <groupId>*</groupId>
                    <artifactId>*</artifactId>
                </exclusion>
            </exclusions>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.felix</groupId>
                <artifactId>maven-bundle-plugin</artifactId>
                <extensions>true</extensions>
                <configuration>
                    <instructions>
                        <Bundle-SymbolicName>${project.artifactId}</Bundle-SymbolicName>
                        <Private-Package>
                            org.wso2.carbon.identity.application.authentication.framework.script.engine.mode.internal
                        </Private-Package>
                        <Export-Package>
                            !org.wso2.carbon.identity.application.authentication.framework.script.engine.mode.internal,
                            org.wso2.carbon.identity.application.authentication.framework.script.engine.mode.*; version="${project.version}"
                        </Export-Package>
                        <Import-Package>
                            org.apache.commons.logging; version="[1.2,2.0)",
                            org.osgi.framework; version="[1.7.0,2.0.0)",
                            org.osgi.service.component; version="[1.2.0,2.0.0)",
                            org.osgi.service.component.annotations; version="[1.2.0,2.0.0)",
                            org.wso2.carbon.identity.application.authentication.framework.config.model.graph.graaljs,
                            org.wso2.carbon.identity.application.authentication.framework.config.model.graph.graaljs.remote,
                            org.wso2.carbon.identity.application.authentication.framework.context,
                        </Import-Package>
                    </instructions>
                </configuration>
            </plugin>
        </plugins>
    </build>

</project>

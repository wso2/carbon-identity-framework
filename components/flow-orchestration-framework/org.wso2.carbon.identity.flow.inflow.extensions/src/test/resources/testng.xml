<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd" >

<suite name="org.wso2.carbon.identity.flow.inflow.extensions">
    <test name="in-flow-extension-executor-tests">
        <classes>
            <class name="org.wso2.carbon.identity.flow.inflow.extensions.executor.HierarchicalPrefixMatcherTest"/>
            <class name="org.wso2.carbon.identity.flow.inflow.extensions.executor.PathTypeAnnotationUtilTest"/>
            <class name="org.wso2.carbon.identity.flow.inflow.extensions.executor.InFlowExtensionRequestBuilderTest"/>
            <class name="org.wso2.carbon.identity.flow.inflow.extensions.executor.InFlowExtensionResponseProcessorTest"/>
            <class name="org.wso2.carbon.identity.flow.inflow.extensions.executor.InFlowExtensionExecutorTest"/>
        </classes>
    </test>
    <test name="in-flow-extension-metadata-tests">
        <classes>
            <class name="org.wso2.carbon.identity.flow.inflow.extensions.metadata.InFlowExtensionContextTreeBuilderTest"/>
        </classes>
    </test>
    <test name="in-flow-extension-model-tests">
        <classes>
            <class name="org.wso2.carbon.identity.flow.inflow.extensions.model.AccessConfigTest"/>
            <class name="org.wso2.carbon.identity.flow.inflow.extensions.model.OperationExecutionResultTest"/>
            <class name="org.wso2.carbon.identity.flow.inflow.extensions.model.InFlowExtensionEventTest"/>
        </classes>
    </test>
</suite>
